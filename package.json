{
	"name": "desk-pet",
	"version": "1.0.0",
	"description": "",
	"main": "src/main/main.js",
	"type": "commonjs",
	"scripts": {
		"start": "electron .",
		"test": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"bundle:live2d": "esbuild src/renderer/shared/live2d-bundle-entry.js --bundle --format=iife --global-name=Live2DRenderer --platform=browser --alias:path=./src/renderer/shared/path-browser.js --external:magic-bytes.js --outfile=src/renderer/shared/live2d-renderer.bundle.js",
		"pack": "npm run bundle:live2d && electron-builder --dir --win",
		"dist": "npm run bundle:live2d && electron-builder --win"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"live2d-renderer": "^0.6.6",
		"lowdb": "^7.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"electron": "^42.3.2",
		"@types/node": "^25.9.1",
		"electron-builder": "^26.15.3",
		"esbuild": "^0.28.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"build": {
		"appId": "com.deskpet.app",
		"productName": "DeskPet",
		"directories": {
			"output": "release"
		},
		"files": [
			"src/**/*",
			"assets/**/*",
			"hiyori_free_zh/**/*",
			"node_modules/**/*",
			"package.json"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": ["x64"]
				},
				{
					"target": "portable",
					"arch": ["x64"]
				}
			]
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true
		},
		"electronDownload": {
			"mirror": "https://npmmirror.com/mirrors/electron/"
		}
	}
}
