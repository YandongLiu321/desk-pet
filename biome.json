{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useNodejsImportProtocol": "warn"
			},
			"a11y": {
				"useButtonType": "off"
			},
			"suspicious": {
				"useIterableCallbackReturn": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	}
}
